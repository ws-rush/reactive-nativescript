    "@gjsify/nativescript-vite": "0.4.44",
    "@lingui/cli": "^6.3.0",
    "@lingui/format-po": "^6.3.0",
    "@nativescript/android": "9.0.4",
    "@nativescript/preview-cli": "1.0.15",
    "@nativescript/types": "~9.0.0",
    "@nativescript/types-android": "9.0.0",
    "@nativescript/types-ios": "9.0.0",
