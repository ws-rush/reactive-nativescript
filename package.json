  "scripts": {
    "dev": "ns run android --no-hmr",
    "start": "ns run android --no-hmr",
    "build": "NS_VITE_DIST_DIR=platforms/android/app/src/main/assets/app ns build android",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "check": "pnpm run lint && pnpm run format:check && pnpm run type-check",
    "type-check": "tsc --noEmit",
    "type-check:watch": "pnpm run type-check -- --watch",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "i18n": "lingui extract --clean && lingui compile"
