{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2017",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmitHelpers": true,
    "noEmitOnError": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "maxNodeModuleJsDepth": 5,
    "jsx": "preserve",
    "lib": [
      "es2017",
      "dom"
    ],
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ],
  "files": [
    "./references.d.ts"
  ],
  "exclude": [
    "node_modules",
    "platforms"
  ]
}
