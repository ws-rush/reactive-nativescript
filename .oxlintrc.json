{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react"],
  "categories": {
    "correctness": "error"
  },
  "settings": {
    "react": {
      "version": "19.2.7"
    }
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": ["src/assets/icons/icon-registry.ts", "src/i18n/locales/**/messages.js"],
  "overrides": [
    {
      "files": ["references.d.ts"],
      "rules": {
        "typescript/triple-slash-reference": "off"
      }
    }
  ],
  "rules": {}
}
